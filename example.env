# Required (default configured for OpenAI)
OPENAI_API_KEY=sk-***

# Optional: Use a different model provider
# ANTHROPIC_API_KEY=sk-ant-***
# GOOGLE_API_KEY=***

# Exa API key for web research
# EXA_API_KEY=***

# IBM i MCP Server connection
DB2i_HOST=
DB2i_USER=
DB2i_PASS=
DB2_PORT=8076
YAML_ALLOW_DUPLICATE_SOURCES=true

