# Model provider API key (at least one required)
ANTHROPIC_API_KEY=sk-ant-***
# OPENAI_API_KEY=sk-***
# GOOGLE_API_KEY=***

# Model configuration (optional - defaults to Anthropic Claude)
# Format: "<provider>:<model_id>"
# See all providers: https://docs.agno.com/models/providers/model-index
# AGENT_MODEL=anthropic:claude-sonnet-4-5
# AGENT_TEAM_MEMBER_MODEL=anthropic:claude-haiku-4-5

# IBM i MCP Server connection
DB2i_HOST=
DB2i_USER=
DB2i_PASS=
DB2_PORT=8076
YAML_ALLOW_DUPLICATE_SOURCES=true

# Exa API key for web research (used by Pal)
# EXA_API_KEY=***

# Database (defaults work out of the box)
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
